# Ticket Analyzer — environment configuration
# Copy this file to `.env` and fill in real values. `docker compose`
# reads it automatically; the frontend reads VITE_* at build time.

# ---- PostgreSQL ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ticket_db

# ---- Backend ----
# Internal URL (used by the backend container talking to the db service).
DATABASE_URL=postgresql://postgres:postgres@db:5432/ticket_db
# Hugging Face sentiment model.
MODEL_NAME=distilbert-base-uncased-finetuned-sst-2-english
# Where the baked-in model weights live inside the image.
HF_HOME=/opt/hf-cache
# Force the container to use the baked weights; fail loudly if missing.
TRANSFORMERS_OFFLINE=1

# ---- Frontend ----
# Same-origin reverse proxy path exposed by Nginx inside the frontend
# container. Keep as `/api` unless you change `frontend/nginx.conf`.
VITE_API_BASE_URL=/api

# Frontend host:port (the Nginx listener and the public-facing port)
FRONTEND_PORT=3000

# Sentiment confidence threshold (0.0–1.0). Below this, the model
# output is downgraded to UNCERTAIN because distilbert-sst-2 has no
# neutral class and low-confidence positives/negatives are unreliable.
SENTIMENT_CONFIDENCE_THRESHOLD=0.80

# Backend service name + port inside the Docker network
BACKEND_HOST=backend
BACKEND_PORT=8000

# Postgres service name + port inside the Docker network
DB_HOST=db
DB_PORT=5432

# ---- DockerHub (used by the README / VM deployment step) ----
DOCKERHUB_USERNAME=your-dockerhub-username
IMAGE_TAG=v1
